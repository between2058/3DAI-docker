# =============================================================================
# AI Services Unified — Machine-specific configuration
#
# Usage:
#   cp .env.example .env
#   vim .env              # fill in paths for THIS machine
#   docker compose up -d
#
# .env is gitignored — never commit it.
# =============================================================================

# ── Shared settings ──────────────────────────────────────────────────────────

# HuggingFace model cache on the host (shared by all three services).
# Each service mounts this to its own internal cache path.
#
# Examples:
#   /pegaai/model_team/huggingface_cache   (prod server)
#   /data/hf_cache                         (dev workstation)
HF_CACHE_HOST_PATH=/pegaai/model_team/huggingface_cache

# CUDA arch list for building CUDA extensions.
# "12.0" = RTX Pro 6000 only (faster build).
# Full list for multi-GPU compatibility:
# TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0;10.0;12.0
TORCH_CUDA_ARCH_LIST=12.0

# Parallel compile jobs (increase if build machine has many cores).
MAX_JOBS=4

# Corporate proxy (set to empty string if not needed).
HTTP_PROXY=http://proxy.intra:80
HTTPS_PROXY=http://proxy.intra:80

# ── GPU assignment ───────────────────────────────────────────────────────────
# Assign each service to a specific GPU index.
# Run `nvidia-smi` on the host to see available devices.
#
# If you have 3+ GPUs, assign one per service for best performance.
# If you have 1 GPU, all three share GPU 0 (watch VRAM usage).

QWEN_GPU_ID=0
RECONVIAGEN_GPU_ID=0
P3SAM_GPU_ID=0

# ── Port mapping (optional — change if defaults conflict) ────────────────────

QWEN_PORT=8190
RECONVIAGEN_PORT=52069
P3SAM_PORT=5001

# ── Optional: HuggingFace token (for gated model repos) ─────────────────────
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
